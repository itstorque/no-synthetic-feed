{
  "manifest_version": 3,
  "name": "AI Content Controller",
  "version": "1.0",
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}